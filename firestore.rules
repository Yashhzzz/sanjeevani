rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Entities: Citizens, ASHA Workers, Hospital Staff
    match /personalData/{appId}/users/{uid}/{collectionName}/{docId} {
      allow get: if uid == request.auth.uid;
      allow list: if uid == request.auth.uid && request.query.limit <= 100;
      allow write: if uid == request.auth.uid;
    }

    // Entities: Public health alerts, water safety data, general risk maps
    match /publicData/{appId}/{collectionName}/{docId} {
      allow get: if true;
      allow list: if request.query.limit <= 100;
      allow write: if request.auth != null; // Only authenticated users can update public data (staff)
    }
  }
}
